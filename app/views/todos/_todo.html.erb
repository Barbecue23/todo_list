<% kanban = local_assigns.fetch(:kanban, false) %>
<div
  id="<%= dom_id todo %>"
  class="rounded-lg border p-4 shadow-sm transition <%= todo.status == "done" ? "bg-green-100 border-green-300" : "bg-white border-slate-200" %>"
  data-todo-id="<%= todo.id %>"
  data-status="<%= todo.status %>"
  data-update-url="<%= todo_path(todo) %>"
  <% if kanban %>
    draggable="true"
    data-action="dragstart->kanban#dragStart dragend->kanban#dragEnd"
  <% end %>
>
  <div class="flex items-start justify-between gap-3 mb-2">
    <h3 class="font-semibold text-slate-800 break-words"><%= todo.title.presence || "Untitled" %></h3>
    <span class="text-xs px-2 py-1 rounded-full border border-slate-300 text-slate-600 bg-white"><%= todo.status %></span>
  </div>

  <% if todo.description.present? %>
    <p class="text-sm text-slate-600 mb-3 break-words"><%= todo.description %></p>
  <% end %>

  <% if todo.due_date.present? %>
    <p class="text-xs text-slate-500 mb-3">Due: <%= l(todo.due_date, format: :short) %></p>
  <% end %>

  <% if kanban %>
    <div class="flex flex-wrap gap-2">
      <%= link_to "Show", todo, class: "text-xs rounded-md px-2 py-1 bg-slate-100 hover:bg-slate-200" %>
      <%= link_to "Edit", edit_todo_path(todo), class: "text-xs rounded-md px-2 py-1 bg-slate-100 hover:bg-slate-200" %>
      <%= button_to "Delete", todo, method: :delete, class: "text-xs rounded-md px-2 py-1 text-white bg-red-600 hover:bg-red-500", data: { turbo_confirm: "Are you sure?" } %>
    </div>
  <% end %>
</div>
