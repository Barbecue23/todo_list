<% content_for :title, "Todos" %>
<div class="w-full" data-controller="kanban" data-kanban-csrf-token-value="<%= form_authenticity_token %>">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-md inline-block" id="notice"><%= notice %></p>
  <% end %>

  <div class="flex justify-between items-center mb-6">
    <h1 class="font-bold text-4xl">Todos</h1>
    <%= link_to "New todo", new_todo_path, class: "rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white block font-medium" %>
  </div>

  <% lanes = {
    "todo" => "Todo",
    "doing" => "Doing",
    "done" => "Done"
  } %>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
    <% lanes.each do |status, title| %>
      <section class="rounded-xl border border-slate-200 bg-slate-50/50">
        <header class="px-4 py-3 border-b border-slate-200 flex items-center justify-between">
          <h2 class="font-semibold text-slate-700"><%= title %></h2>
          <span class="text-xs px-2 py-1 rounded-full bg-white border border-slate-200 text-slate-500"><%= @todos_by_status.fetch(status, []).size %></span>
        </header>

        <div
          class="p-3 min-h-[380px] space-y-3"
          data-kanban-target="lane"
          data-status="<%= status %>"
          data-action="dragover->kanban#dragOver dragenter->kanban#dragEnter dragleave->kanban#dragLeave drop->kanban#drop"
        >
          <% @todos_by_status.fetch(status, []).each do |todo| %>
            <%= render todo, kanban: true %>
          <% end %>
        </div>
      </section>
    <% end %>
  </div>

  <% if @todos_by_status.values.flatten.empty? %>
    <p class="text-center my-10 text-slate-500">No todos found.</p>
  <% end %>
</div>
